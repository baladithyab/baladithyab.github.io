---
/**
 * /projects — listing page for everything tagged `codeseys-embed`.
 *
 * Reads the `projects` content collection (populated by
 * `src/scripts/sync-project-manifests.ts` at prebuild time), sorts by
 * `category.year` desc, and renders one card per project linking off to
 * `/projects/[slug]`.
 */

import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const entries = await getCollection('projects')

// Sort: most recent year first, ties broken by slug for determinism.
const sorted = [...entries].sort((a, b) => {
  const ay = a.data.category.year
  const by = b.data.category.year
  if (ay !== by) return by - ay
  return a.data.slug.localeCompare(b.data.slug)
})

function categoryLabel(c: (typeof entries)[number]['data']['category']): string {
  switch (c.kind) {
    case 'college':
      return `${c.school} ${c.code} · ${c.year}`
    case 'hackathon':
      return `${c.event} · ${c.year}`
    case 'side':
      return `Side project · ${c.year}`
    case 'work':
      return c.org ? `${c.org} · ${c.year}` : `Work · ${c.year}`
    case 'research':
      return c.venue ? `${c.venue} · ${c.year}` : `Research · ${c.year}`
  }
}

function completionDot(level: 'wip' | 'works' | 'ships'): { class: string; label: string } {
  switch (level) {
    case 'wip':
      return { class: 'bg-amber-400', label: 'work-in-progress' }
    case 'works':
      return { class: 'bg-sky-400', label: 'works locally' }
    case 'ships':
      return { class: 'bg-emerald-400', label: 'ships' }
  }
}
---

<BaseLayout
  title="Projects | Baladithya B"
  description="Interactive embeds of college, hackathon, and side projects — graphics demos, language tools, and a few weirder things."
  ogTag="Projects"
  ogAccent="#a78bfa"
>
  <main class="mx-auto w-full max-w-[1600px] px-4 py-10 sm:px-6 sm:py-12">
    <header class="mb-8 sm:mb-10">
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Projects</h1>
      <p class="mt-3 max-w-3xl text-sm text-muted-foreground sm:text-base">
        Embeddable demos of work I've shipped. Each one is a real artifact
        served from <code class="rounded bg-muted px-1 py-0.5 text-xs">assets-r2.codeseys.io</code>,
        built by its own GitHub Actions workflow, and discovered automatically
        by the site at build time. Source repos and the architecture doc are
        linked from each project's page.
      </p>
    </header>

    {
      sorted.length === 0 ? (
        <div class="rounded-xl border border-dashed py-16 text-center">
          <p class="text-sm text-muted-foreground">
            No projects discovered yet. Add the <code class="rounded bg-muted px-1 py-0.5 text-xs">codeseys-embed</code> topic to a repo with a <code class="rounded bg-muted px-1 py-0.5 text-xs">web.codeseys.json</code> manifest.
          </p>
        </div>
      ) : (
        <div
          class="grid auto-rows-fr gap-4"
          style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));"
        >
          {sorted.map((entry) => {
            const dot = completionDot(entry.data.completionLevel)
            return (
              <a
                href={`/projects/${entry.data.slug}`}
                class="group flex flex-col rounded-xl border bg-card p-5 transition-all hover:border-primary/50 hover:shadow-md"
              >
                <div class="mb-2 flex items-center justify-between gap-2 text-xs">
                  <span class="font-mono text-muted-foreground">
                    {categoryLabel(entry.data.category)}
                  </span>
                  <span class="inline-flex items-center gap-1.5 text-muted-foreground">
                    <span
                      class={`size-1.5 rounded-full ${dot.class}`}
                      aria-label={dot.label}
                      title={dot.label}
                    />
                    {entry.data.completionLevel}
                  </span>
                </div>

                <h2 class="text-base font-semibold leading-snug text-foreground group-hover:text-primary">
                  {entry.data.title}
                </h2>
                <p class="mt-2 line-clamp-3 flex-1 text-sm text-muted-foreground">
                  {entry.data.description}
                </p>

                {entry.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {entry.data.tags.slice(0, 5).map((tag) => (
                      <span class="inline-flex items-center rounded-md border bg-background/60 px-1.5 py-0.5 text-[11px] font-medium text-muted-foreground">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            )
          })}
        </div>
      )
    }
  </main>
</BaseLayout>
