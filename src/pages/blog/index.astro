---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import BlogGrid, { type BlogGridPost } from '../../components/BlogGrid'
import {
  filterPublishedPosts,
  formatBlogCardDate,
  getRichPreview,
  sortBlogPosts,
} from '../../lib/blog'

const posts = sortBlogPosts(filterPublishedPosts(await getCollection('blog')))

// Build rich-text previews at SSR time so crawlers see formatted content.
// Marshall the data into a flat shape with pre-formatted dates so the
// React island doesn't need a date library client-side.
const blogGridPosts: BlogGridPost[] = await Promise.all(
  posts.map(async (post) => ({
    id: post.id,
    href: `/blog/${post.id}`,
    title: post.data.title,
    description: post.data.description,
    previewHtml: await getRichPreview(post, 220),
    publishedAt: post.data.publishedAt.toISOString(),
    updatedAt: post.data.updatedAt ? post.data.updatedAt.toISOString() : null,
    tags: post.data.tags ?? [],
    publishedAtDisplay: formatBlogCardDate(post.data.publishedAt),
    updatedAtDisplay: post.data.updatedAt
      ? formatBlogCardDate(post.data.updatedAt)
      : null,
  })),
)
---

<BaseLayout title="Blog | Baladithya B">
  <main class="container mx-auto max-w-[1600px] px-4 py-8 lg:px-6">
    <div class="mb-6">
      <h1 class="mb-1 text-3xl font-bold">Blog Posts</h1>
      <p class="text-sm text-muted-foreground">
        Notes on AI, infrastructure, distributed systems, and whatever I'm
        building this week.
      </p>
    </div>
    {
      blogGridPosts.length === 0 ? (
        <p class="text-center text-muted-foreground">
          No blog posts available at the moment.
        </p>
      ) : (
        <BlogGrid client:load posts={blogGridPosts} />
      )
    }
  </main>
</BaseLayout>

<style is:global>
  /* Inline-element styling for the SSR-rendered rich previews. Matches the
     prior design (link colour, code chip, bold weight) but scoped to the
     `.blog-preview` containers inside <BlogGrid>. */
  .blog-preview p {
    margin: 0 0 0.4em;
  }
  .blog-preview p:last-child {
    margin-bottom: 0;
  }
  .blog-preview a {
    color: hsl(var(--primary));
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-preview code {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875em;
    padding: 0.05em 0.3em;
    border-radius: 3px;
    background: rgba(127, 127, 127, 0.15);
  }
  .blog-preview strong {
    font-weight: 600;
  }
</style>
