---
import BaseLayout from '@/layouts/BaseLayout.astro'
import BentoGrid from '@/components/BentoGrid.astro'
import ServiceGrid, { type ServiceGridEndpoint } from '@/components/ServiceGrid'
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from '@/components/ui/card'
import { Badge } from '@/components/ui/badge'
import { type AuthEnv, isAuthConfigured } from '@/lib/auth'
import { type GitHubEnv, getGitHubSummary } from '@/lib/github'
import {
  type GatusEnv,
  getGatusSummary,
  formatUptime,
  formatResponse,
} from '@/lib/gatus'
import { getRuntimeEnv } from '@/lib/runtime-env'

type StatusEnv = AuthEnv & GitHubEnv & GatusEnv

const runtimeEnv = getRuntimeEnv<StatusEnv>()
const authConfigured = isAuthConfigured(runtimeEnv)
const { user, session } = Astro.locals

// Run the two server-side fetches in parallel; both have their own cache,
// timeout, and graceful-fallback so a single failing upstream doesn't take
// the whole page down.
const [githubSummary, gatusSummary] = await Promise.all([
  getGitHubSummary(runtimeEnv).catch(() => null),
  getGatusSummary(runtimeEnv).catch(() => null),
])

const githubOk = Boolean(githubSummary)

// Pre-compute display strings server-side so the rendered HTML matches what
// crawlers see (no React hydration needed for the status content).
const gatusOk = Boolean(gatusSummary)
const totalEndpoints = gatusSummary?.aggregate.total ?? 0
const upEndpoints = gatusSummary?.aggregate.up ?? 0
const uptimeDisplay = gatusOk ? formatUptime(gatusSummary!.aggregate.uptimeRatio) : '—'
const avgResponseDisplay = gatusOk
  ? formatResponse(gatusSummary!.aggregate.avgResponseMs)
  : '—'

// Categorize each endpoint so the filter chips and "Category" sort have
// meaningful buckets. Heuristic: Gatus's own group string is preferred when
// it's user-friendly; otherwise we infer from name suffix tokens
// ("(Public)", "(Internal)") and known service-name patterns.
function categorize(name: string, group?: string): string {
  if (name.includes('(Public)') || name.endsWith('(Public TCP)')) return 'Public Surface'
  if (name.includes('(Internal)')) return 'Internal Services'
  if (
    /^(Cluster DNS|Kubernetes API|Cloudflared Tunnel|Traefik Gateway|SeaweedFS .*)$/i.test(
      name,
    )
  ) {
    return 'Infrastructure'
  }
  // *arr media stack and helpers — separate from general "apps & tools" so
  // the filter chips read as distinct buckets users can drill into.
  if (
    /^(bazarr|checkrr|cleanuparr|dispatcharr|jellyfin|lidarr|plex|prowlarr|qbittorrent|radarr|reclaimerr|sabnzbd|seerr|sonarr|tdarr)$/i.test(
      name.trim(),
    )
  ) {
    return 'Media Stack'
  }
  // Honour an explicit Gatus group label if it's set to something sensible
  // (some endpoints arrive ungrouped, others use a humanised group label).
  if (group && group.trim() && !/^(External|Personal)$/i.test(group)) {
    return group
  }
  return 'Apps & Tools'
}

// Flat, fully-categorized list — passed to <ServiceGrid> for client-side
// filtering/sorting/search. Server still emits the full <article> set so
// crawlers (and noscript users) see all endpoints.
const serviceGridEndpoints: ServiceGridEndpoint[] = (gatusSummary?.endpoints ?? []).map(
  (ep) => ({
    key: ep.key,
    name: ep.name,
    group: ep.group ?? '',
    category: categorize(ep.name, ep.group),
    detailUrl: ep.detailUrl,
    publicUrl: ep.publicUrl,
    current: ep.current,
    recentUptime: ep.recentUptime,
    recentSamples: ep.recentSamples,
    recentHistory: ep.recentHistory,
  }),
)

function relativeAge(iso: string | null): string {
  if (!iso) return 'never'
  const seconds = Math.max(0, (Date.now() - Date.parse(iso)) / 1000)
  if (seconds < 60) return `${Math.round(seconds)}s ago`
  if (seconds < 3600) return `${Math.round(seconds / 60)}m ago`
  if (seconds < 86400) return `${Math.round(seconds / 3600)}h ago`
  return `${Math.round(seconds / 86400)}d ago`
}
---

<BaseLayout
  title="Server Status | Baladithya B"
  description="Live service status and uptime monitoring across the codeseys.io infrastructure, powered by Gatus."
  ogTag="Status"
  ogAccent="#34d399"
>
  <section class="container mx-auto max-w-[1600px] px-4 py-8 lg:px-6">
    <div class="mb-8 text-center">
      <h1 class="mb-2 text-3xl font-bold">Server Status</h1>
      <p class="text-muted-foreground">
        Live monitoring powered by
        <a
          href={gatusSummary?.sourceUrl ?? 'https://gatus.io'}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-primary underline underline-offset-2"
        >
          Gatus
        </a>
        {gatusSummary?.lastSeen && (
          <>
            <span class="mx-1">·</span>
            <span>last update {relativeAge(gatusSummary.lastSeen)}</span>
          </>
        )}
      </p>
    </div>

    <BentoGrid>
      <!--
        Top row at xl: System Overview (6) | Auth (3) | GitHub (3)
        Top row at md: System Overview (6) | Auth (3) | GitHub (3)
        Mobile: stack
      -->

      <!-- System Overview — driven by live Gatus data -->
      <Card className="md:col-span-6 xl:col-span-6">
        <CardHeader>
          <div class="flex items-center justify-between">
            <CardTitle>System Overview</CardTitle>
            <Badge
              variant="outline"
              className={
                gatusOk
                  ? 'border-green-500/30 bg-green-500/10 text-green-700 dark:text-green-400'
                  : 'text-muted-foreground'
              }
            >
              {gatusOk ? `${upEndpoints} / ${totalEndpoints} healthy` : 'Unavailable'}
            </Badge>
          </div>
          <CardDescription>
            {gatusOk
              ? 'Aggregate health across all endpoints monitored by Gatus.'
              : 'Live monitoring data is temporarily unavailable. The page will refresh automatically.'}
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-4 sm:grid-cols-3">
            <div class="rounded-lg border bg-card p-4">
              <div class="text-sm text-muted-foreground">Uptime</div>
              <div class="mt-2 text-3xl font-semibold tabular-nums">
                {uptimeDisplay}
              </div>
            </div>
            <div class="rounded-lg border bg-card p-4">
              <div class="text-sm text-muted-foreground">Avg Response</div>
              <div class="mt-2 text-3xl font-semibold tabular-nums">
                {avgResponseDisplay}
              </div>
            </div>
            <div class="rounded-lg border bg-card p-4">
              <div class="text-sm text-muted-foreground">Services</div>
              <div class="mt-2 text-3xl font-semibold tabular-nums">
                {gatusOk ? totalEndpoints : '—'}
              </div>
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Auth Status -->
      <Card className="md:col-span-3 xl:col-span-3">
        <CardHeader>
          <div class="flex items-center justify-between">
            <CardTitle>Authentication</CardTitle>
            <Badge variant="outline" className="text-muted-foreground">
              {authConfigured ? 'Configured' : 'Not configured'}
            </Badge>
          </div>
          <CardDescription>
            OIDC (Auth0/Keycloak) integration status.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="space-y-2">
            <div class="flex items-baseline justify-between rounded-md border bg-card/50 px-3 py-2">
              <span class="text-sm text-muted-foreground">OIDC</span>
              <span class="text-sm font-semibold">
                {authConfigured ? 'Enabled' : 'Disabled'}
              </span>
            </div>
            <div class="flex items-baseline justify-between rounded-md border bg-card/50 px-3 py-2">
              <span class="text-sm text-muted-foreground">Session</span>
              <span class="text-sm font-semibold">
                {session ? 'Signed in' : 'Signed out'}
              </span>
            </div>
            <div class="flex items-baseline justify-between gap-2 rounded-md border bg-card/50 px-3 py-2">
              <span class="text-sm text-muted-foreground">User</span>
              <span class="truncate text-sm font-semibold">
                {user?.email ?? user?.name ?? user?.id ?? 'N/A'}
              </span>
            </div>
          </div>
          {authConfigured && (
            <div class="mt-4 flex flex-wrap gap-2">
              <a
                href={session ? '/api/auth/logout' : '/login'}
                class="inline-flex items-center rounded-md bg-secondary px-2.5 py-1.5 text-xs font-medium text-secondary-foreground hover:bg-secondary/80"
              >
                {session ? 'Logout' : 'Login'}
              </a>
              <a
                href="/api/auth/session"
                class="inline-flex items-center rounded-md bg-secondary px-2.5 py-1.5 text-xs font-medium text-secondary-foreground hover:bg-secondary/80"
              >
                Session
              </a>
            </div>
          )}
        </CardContent>
      </Card>

      <!-- GitHub Status -->
      <Card className="md:col-span-3 xl:col-span-3">
        <CardHeader>
          <div class="flex items-center justify-between">
            <CardTitle>GitHub</CardTitle>
            <Badge variant="outline" className="text-muted-foreground">
              {githubOk ? 'Available' : 'Unavailable'}
            </Badge>
          </div>
          <CardDescription>
            Server-side GitHub fetch (used by /profile). Cloudflare-cached.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="space-y-2">
            <div class="flex items-baseline justify-between rounded-md border bg-card/50 px-3 py-2">
              <span class="text-sm text-muted-foreground">API</span>
              <span class="text-sm font-semibold">
                {githubOk ? 'OK' : 'Error'}
              </span>
            </div>
            <div class="flex items-baseline justify-between rounded-md border bg-card/50 px-3 py-2">
              <span class="text-sm text-muted-foreground">Cache</span>
              <span class="text-sm font-semibold">
                {githubOk ? 'Warmable' : 'N/A'}
              </span>
            </div>
            <div class="flex items-baseline justify-between rounded-md border bg-card/50 px-3 py-2">
              <span class="text-sm text-muted-foreground">Token</span>
              <span class="text-sm font-semibold">
                {runtimeEnv?.GITHUB_TOKEN ? 'Set' : 'Not set'}
              </span>
            </div>
          </div>
          <div class="mt-4">
            <a
              href="/api/github/summary"
              class="inline-flex items-center rounded-md bg-secondary px-2.5 py-1.5 text-xs font-medium text-secondary-foreground hover:bg-secondary/80"
            >
              View summary →
            </a>
          </div>
        </CardContent>
      </Card>

      <!--
        Service grid — every endpoint is its own card, auto-flowing across
        every available column. Filtering, sort, and search are handled by
        the React island; SSR still emits the initial filter state's full
        card set (defaults: All / Category sort / no search), so crawlers
        and no-JS users see the complete list.
      -->
      {gatusOk && serviceGridEndpoints.length > 0 && (
        <ServiceGrid client:load endpoints={serviceGridEndpoints} />
      )}

      {!gatusOk && (
        <Card className="md:col-span-6 xl:col-span-12">
          <CardContent>
            <div class="py-12 text-center">
              <p class="text-sm text-muted-foreground">
                Live monitoring data could not be reached. Verify
                <a
                  href={gatusSummary?.sourceUrl ?? 'https://status.codeseys.io'}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="ml-1 font-medium text-primary underline underline-offset-2"
                >
                  the Gatus instance
                </a>
                is online and reachable.
              </p>
            </div>
          </CardContent>
        </Card>
      )}

      <!-- Footer note spans full width -->
      <div
        class="rounded-lg border border-dashed border-muted-foreground/30 p-6 text-center md:col-span-6 xl:col-span-12"
      >
        <p class="text-sm text-muted-foreground">
          Detailed history, per-endpoint condition results, and badges are
          available on the
          <a
            href={gatusSummary?.sourceUrl ?? 'https://status.codeseys.io'}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-primary underline underline-offset-2"
          >
            full Gatus dashboard
          </a>.
        </p>
      </div>
    </BentoGrid>
  </section>
</BaseLayout>
